# sed.i Backend — Environment Variables
# Copy to .env and fill in real values.
# Generate SECRET_KEY with: openssl rand -hex 32

# ── Database ───────────────────────────────────────────────────────────────────
# Note: docker compose runs Postgres on port 5433 (not 5432) to avoid conflicts.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/content_queue

# ── Cache / Queue (Celery broker) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-replace-with-output-of-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── OpenAI — embeddings + summarization + auto-tagging ───────────────────────
# Leave empty to disable semantic search, summaries, and AI tags.
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Email (Resend) — optional ─────────────────────────────────────────────────
# Leave empty to disable email verification and password reset.
RESEND_API_KEY=re_your_resend_api_key
EMAILS_FROM_EMAIL=noreply@yourdomain.com
EMAILS_FROM_NAME=sed.i Team
FRONTEND_URL=http://localhost:3000

# ── MCP OAuth — optional ──────────────────────────────────────────────────────
# Required for cloud MCP (Claude.ai integration). Not needed for stdio (Claude Desktop).
# API_BASE_URL must be the public-facing backend URL (used in OAuth discovery).
API_BASE_URL=https://api.yourdomain.com
MCP_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Analytics (PostHog) — optional ───────────────────────────────────────────
# Leave empty to disable analytics.
POSTHOG_API_KEY=phc_your_posthog_key
POSTHOG_HOST=https://us.i.posthog.com

# ── Discogs — optional ────────────────────────────────────────────────────────
# Required for vinyl record metadata fetching (SHOW_CRATES feature).
DISCOGS_TOKEN=your-discogs-personal-access-token

# ── AI provider selection ─────────────────────────────────────────────────────
# LLM_PROVIDER: "openai" (default) or "bedrock"
# EMBED_PROVIDER: "openai" (default) or "bedrock"
LLM_PROVIDER=openai
EMBED_PROVIDER=openai

# ── AWS (required if LLM_PROVIDER=bedrock or EMBED_PROVIDER=bedrock) ─────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# ── AWS S3 (optional — for PDF upload and object storage) ────────────────────
AWS_S3_BUCKET=
AWS_S3_PRESIGN_EXPIRY=3600

# ── Observability — optional ──────────────────────────────────────────────────
# Braintrust: AI eval logging
BRAINTRUST_API_KEY=

# Sentry: error tracking
SENTRY_DSN=

# OpenTelemetry: tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=sedi
SEDI_ENV=development

# ── Prefect — optional ────────────────────────────────────────────────────────
# Enable for durable task orchestration (falls back to Celery if disabled).
PREFECT_ENABLED=False
PREFECT_API_URL=
PREFECT_API_KEY=

# ── Tuning ────────────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD_CONNECTIONS=0.3
SIMILARITY_THRESHOLD_TAGS=0.75
DEBUG=True
